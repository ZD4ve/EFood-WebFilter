@using Microsoft.AspNetCore.Components.Web

<div class="food-card @(IsSelected ? "is-selected" : string.Empty)"
     @onclick="OnClick"
     @onkeydown="OnKeyDown"
     role="button"
     tabindex="0"
     aria-pressed="@IsSelected"
     aria-label="@Food.Name">
    <div class="food-header">
        <h5 class="food-name">@Food.Name</h5>
        <span class="protein-ratio">@Food.ProteinPer100Calorie.ToString("0.0") / 25</span>
    </div>

    <div class="food-body">
        <div class="food-image" @key="Food.ImageUrl">
            <img src="@Food.ImageUrl"
                 alt="@Food.Name"
                 loading="lazy"
                 decoding="async"
                 onload="this.parentElement?.classList.remove('is-error'); this.parentElement?.classList.add('is-loaded'); this.style.display='block';"
                 onerror="this.parentElement?.classList.remove('is-loaded'); this.parentElement?.classList.add('is-error'); this.style.display='none';" />

            <div class="image-placeholder loading" aria-hidden="true">
                <span>Kép betöltése...</span>
            </div>
            <div class="image-placeholder error" aria-hidden="true">
                <span>Nincs kép ehhez az ételhez</span>
            </div>
        </div>

        <div class="food-macros">
            <div class="macro-row important">
                <span class="macro-label">Kalória:</span>
                <span class="macro-value">@Food.Calories.ToString("0") kcal</span>
            </div>
            <div class="macro-row important">
                <span class="macro-label">Fehérje:</span>
                <span class="macro-value">@Food.Protein.ToString("0.0")g</span>
            </div>
            <div class="macro-row">
                <span class="macro-label">Szénhidrát:</span>
                <span class="macro-value">@Food.Carbohydrates.ToString("0.0")g</span>
            </div>
            <div class="macro-row">
                <span class="macro-label">Zsír:</span>
                <span class="macro-value">@Food.Fat.ToString("0.0")g</span>
            </div>
            <div class="food-price">
                @Food.Price Ft
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public EFoodAPI.Food Food { get; set; } = null!;

    [Parameter]
    public bool IsSelected { get; set; }

    [Parameter]
    public EventCallback<EFoodAPI.Food> OnToggleSelection { get; set; }

    private async Task OnClick()
    {
        await OnToggleSelection.InvokeAsync(Food);
    }

    private async Task OnKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter" || args.Key == " ")
        {
            await OnToggleSelection.InvokeAsync(Food);
        }
    }
}
