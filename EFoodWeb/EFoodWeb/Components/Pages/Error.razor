@page "/Error"
@using System.Diagnostics

<PageTitle>Error</PageTitle>

<section class="status-sheet danger">
    <p class="status-kicker">Hibarendszer</p>
    <h1>Rendszerhiba</h1>
    <p>Hiba tortent a keres feldolgozasa kozben.</p>

    @if (ShowRequestId)
    {
        <p>
            <strong>Keres azonosito:</strong> <code>@RequestId</code>
        </p>
    }

    <h2>Fejlesztoi mod</h2>
    <p>
        A <strong>Development</strong> kornyezetben reszletesebb hibaadatok jelennek meg.
    </p>
    <p>
        <strong>Uzemi kornyezetben a Development mod ne legyen bekapcsolva.</strong>
        Ez erzekeny hibainformaciot jelenithet meg a felhasznaloknak.
        Helyi hibakereseshez allitsd az <strong>ASPNETCORE_ENVIRONMENT</strong> valtozot <strong>Development</strong> ertekre,
        majd inditsd ujra az alkalmazast.
    </p>
</section>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
