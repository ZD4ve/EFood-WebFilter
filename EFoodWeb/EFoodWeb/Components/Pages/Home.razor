@page "/"
@rendermode InteractiveServer

<PageTitle>E-Food Heti Menu</PageTitle>

<section class="ps-hero">
    <div class="ps-hero-mark">
        <img src="favicon.png" alt="e-Food" />
    </div>
    <div class="ps-hero-copy">
        <p class="ps-kicker">E-food Heti Választó</p>
        <h1>Válassz Tudatosan a Hétre</h1>
        <p>Heti ellátási felület kalória- és fehérjeoptimált napi választáshoz.</p>
    </div>
    <a href="https://rendel.e-food.hu" target="_blank" rel="noopener noreferrer" class="ps-portal-link">
        E-Food Portál
    </a>
</section>

<section class="ps-controls" aria-label="Szűrők és beállítások">
    <div class="directive-grid">
        <section class="directive-block">
            <h2>Időzítési Mátrix</h2>
            <div class="field-grid two-up">
                <label class="ps-field" for="weekSelect">
                    <span class="field-label">Heti szakasz</span>
                    <select id="weekSelect" @bind="SelectedWeekOffset" @bind:after="LoadFoods">
                        <option value="0">Aktuális hét</option>
                        <option value="1">Következő hét</option>
                    </select>
                </label>

                <label class="ps-field" for="daySelect">
                    <span class="field-label">Nap</span>
                    <select id="daySelect" @bind="SelectedDate">
                        @foreach (var date in AvailableDates)
                        {
                            <option value="@date.ToString("yyyy-MM-dd")">@date.ToString("dddd, MMM d", new System.Globalization.CultureInfo("hu-HU"))</option>
                        }
                    </select>
                </label>
            </div>
        </section>

        <section class="directive-block">
            <h2>Tápanyag Határok</h2>
            <div class="field-grid four-up">
                <label class="ps-field" for="minCalories">
                    <span class="field-label">Kalória minimum</span>
                    <input type="number" id="minCalories" placeholder="0" @bind="MinCalories" />
                </label>

                <label class="ps-field" for="maxCalories">
                    <span class="field-label">Kalória maximum</span>
                    <input type="number" id="maxCalories" placeholder="nincs" @bind="MaxCalories" />
                </label>

                <label class="ps-field" for="minProtein">
                    <span class="field-label">Fehérje minimum</span>
                    <input type="number" id="minProtein" placeholder="0" @bind="MinProtein" />
                </label>

                <label class="ps-field" for="maxProtein">
                    <span class="field-label">Fehérje maximum</span>
                    <input type="number" id="maxProtein" placeholder="nincs" @bind="MaxProtein" />
                </label>
            </div>
        </section>

        <section class="directive-block">
            <h2>Rendezés</h2>
            <div class="field-grid one-up">
                <label class="ps-field" for="sortBy">
                    <span class="field-label">Prioritás</span>
                    <select id="sortBy" @bind="SortBy">
                        <option value="HighestProtein">Legtöbb fehérje</option>
                        <option value="HighestScore">Legjobb arány / 100 kcal</option>
                        <option value="HighestCalories">Legtöbb kalória</option>
                        <option value="LowestCalories">Legkevesebb kalória</option>
                    </select>
                </label>
            </div>
        </section>
    </div>
</section>

@if (IsLoading)
{
    <div class="ps-state-box loading" role="status" aria-live="polite">
        <div class="spinner-border" aria-hidden="true"></div>
        <p>A menük betöltése folyamatban...</p>
    </div>
}
else if (Foods is not null && Foods.Count > 0)
{
    <section class="results-container" aria-label="Napi étellista">
        @foreach (var dayGroup in FilteredAndSortedFoods.GroupBy(f => f.Date).OrderBy(g => g.Key))
        {
            <div class="day-section">
                <h3 class="day-header">@dayGroup.Key.ToString("dddd, MMMM d", new System.Globalization.CultureInfo("hu-HU"))</h3>
                <p class="day-subtitle">@(dayGroup.Count()) étel érhető el ezen a napon</p>

                <div class="food-grid">
                    @foreach (var food in dayGroup)
                    {
                        <FoodCard Food="food" 
                                  IsSelected="SelectedFoods.Contains(food)" 
                                  OnToggleSelection="ToggleFoodSelection" />
                    }
                </div>
            </div>
        }
    </section>
}
else if (!IsLoading)
{
    <div class="ps-state-box empty">
        <h2>Nincs találat</h2>
        <p>Nincsenek elérhető ételek ehhez a beállítás kombinációhoz.</p>
    </div>
}

@if (SelectedFoods.Count > 0)
{
    <aside class="allocation-panel" aria-label="Aktuális választás">
        <div class="allocation-list">
            <p class="allocation-title">Kiválasztott ételek</p>
            @foreach (var food in SelectedFoods)
            {
                <div class="allocation-item">@food.Name</div>
            }
        </div>

        <div class="allocation-metrics">
            <div class="metric">
                <span class="metric-value">@TotalCalories.ToString("0")</span>
                <span class="metric-label">kcal</span>
            </div>
            <div class="metric">
                <span class="metric-value">@TotalProtein.ToString("0.0")</span>
                <span class="metric-label">fehérje (g)</span>
            </div>

            <a href="https://rendel.e-food.hu" target="_blank" rel="noopener noreferrer" class="allocation-action">
                RENDELÉS INDÍTÁSA
            </a>
        </div>
    </aside>
}

@code {
    private List<EFoodAPI.Food>? Foods;
    private bool IsLoading = true;
    private int SelectedWeekOffset;
    private string SelectedDate = "";

    private double? MinCalories;
    private double? MaxCalories;
    private double? MinProtein;
    private double? MaxProtein;
    private string SortBy = "HighestProtein";

    private Dictionary<DateOnly, HashSet<EFoodAPI.Food>> SelectionsByDate = new();

    private DateOnly CurrentDateOnly => string.IsNullOrWhiteSpace(SelectedDate) 
        ? DateOnly.FromDateTime(DateTime.Now) 
        : DateOnly.Parse(SelectedDate);

    private HashSet<EFoodAPI.Food> SelectedFoods
    {
        get
        {
            if (!SelectionsByDate.ContainsKey(CurrentDateOnly))
            {
                SelectionsByDate[CurrentDateOnly] = new HashSet<EFoodAPI.Food>();
            }
            return SelectionsByDate[CurrentDateOnly];
        }
    }

    private double TotalCalories => SelectedFoods.Sum(f => f.Calories);
    private double TotalProtein => SelectedFoods.Sum(f => f.Protein);

    private List<DateOnly> AvailableDates => 
        Foods?.Select(f => f.Date).Distinct().OrderBy(d => d).ToList() ?? new List<DateOnly>();

    protected override async Task OnInitializedAsync()
    {
        var dayAfterTomorrow = DateOnly.FromDateTime(DateTime.Now.AddDays(2));
        var currentWeek = System.Globalization.ISOWeek.GetWeekOfYear(DateTime.Now);
        var dayAfterTomorrowWeek = System.Globalization.ISOWeek.GetWeekOfYear(DateTime.Now.AddDays(2));

        SelectedWeekOffset = dayAfterTomorrowWeek - currentWeek;

        await LoadFoods();

        if (AvailableDates.Contains(dayAfterTomorrow))
        {
            SelectedDate = dayAfterTomorrow.ToString("yyyy-MM-dd");
        }
        else if (AvailableDates.Count > 0)
        {
            SelectedDate = AvailableDates[0].ToString("yyyy-MM-dd");
        }
    }

    private async Task LoadFoods()
    {
        IsLoading = true;
        StateHasChanged();

        try
        {
            Foods = await global::EFoodAPI.EFoodAPI.GetFoods(SelectedWeekOffset);
        }
        catch (Exception ex)
        {
            Foods = new List<EFoodAPI.Food>();
            Console.WriteLine($"Error loading foods: {ex.Message}");
        }

        IsLoading = false;

        var tomorrow = DateOnly.FromDateTime(DateTime.Now.AddDays(1));
        if (AvailableDates.Contains(tomorrow))
        {
            SelectedDate = tomorrow.ToString("yyyy-MM-dd");
        }
        else if (AvailableDates.Count > 0)
        {
            SelectedDate = AvailableDates[0].ToString("yyyy-MM-dd");
        }
    }

    private IEnumerable<EFoodAPI.Food> FilteredAndSortedFoods
    {
        get
        {
            if (Foods is null) return Enumerable.Empty<EFoodAPI.Food>();

            IEnumerable<EFoodAPI.Food> result = Foods;

            result = result.Where(f => f.Orderable);

            if (!string.IsNullOrWhiteSpace(SelectedDate))
            {
                var selectedDateOnly = DateOnly.Parse(SelectedDate);
                result = result.Where(f => f.Date == selectedDateOnly);
            }

            if (MinCalories.HasValue)
            {
                result = result.Where(f => f.Calories >= MinCalories.Value);
            }

            if (MaxCalories.HasValue)
            {
                result = result.Where(f => f.Calories <= MaxCalories.Value);
            }

            if (MinProtein.HasValue)
            {
                result = result.Where(f => f.Protein >= MinProtein.Value);
            }

            if (MaxProtein.HasValue)
            {
                result = result.Where(f => f.Protein <= MaxProtein.Value);
            }

            result = SortBy switch
            {
                "HighestProtein" => result.OrderByDescending(f => f.Protein),
                "HighestScore" => result.OrderByDescending(f => f.ProteinPer100Calorie),
                "HighestCalories" => result.OrderByDescending(f => f.Calories),
                "LowestCalories" => result.OrderBy(f => f.Calories),
                _ => result.OrderBy(f => f.Date)
            };

            return result;
        }
    }

    private void ToggleFoodSelection(EFoodAPI.Food food)
    {
        if (SelectedFoods.Contains(food))
        {
            SelectedFoods.Remove(food);
        }
        else
        {
            SelectedFoods.Add(food);
        }
    }
}

